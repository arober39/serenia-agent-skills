# Optional: synthetic traffic driver target (defaults to http://localhost:8000)
# SERENIA_BASE_URL=http://localhost:8000

# Legacy Datadog settings (left in place, no longer required for the demo)
DD_API_KEY=your-datadog-api-key
DD_SITE=us5.datadoghq.com
DD_AGENT_HOST=localhost
DD_TAGS=launchdarkly.project_id:your-launchdarkly-client-side-id
